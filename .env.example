# Copy to .env and fill in. NEVER commit .env (it is git-ignored).

# Public address Caddy serves on:
#   a domain you control -> automatic HTTPS (recommended for a real run)
#   :80                  -> HTTP only, for testing against the server's IP first
SITE_ADDRESS=experiments.youruniversity.edu

# Secrets — generate long random strings (e.g. `openssl rand -hex 32`).
# Keep PID_SALT off any machine that also stores the participant-ID lookup table.
PID_SALT=change-me-to-a-long-random-secret
ADMIN_TOKEN=change-me-to-a-long-random-secret
RNG_BASE_SEED=20260611

# Study-4 writing assistant. Leave the key empty to run the deterministic offline
# assistant; set it to use the pinned Claude Haiku model.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=

# Completion codes from each study's recruitment (e.g. Prolific) page.
COMPLETION_CODE_S3=
COMPLETION_CODE_S4=
